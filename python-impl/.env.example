# LLM Provider (MiniMax preferred, OpenAI-compatible)
MINIMAX_API_KEY=sk-your-minimax-api-key
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.1-highspeed

# Optional OpenAI fallback
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o

# Redis
REDIS_URL=redis://localhost:6379/0

# Vector Store
VECTOR_STORE_TYPE=faiss
FAISS_INDEX_PATH=./vector_store/faiss_index
# MILVUS_HOST=localhost
# MILVUS_PORT=19530

# OpenTelemetry
OTEL_SERVICE_NAME=smart-cs-multi-agent
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACES_SAMPLER=always_on
OTEL_ENABLE_CONSOLE_EXPORT=false

# LangSmith
LANGSMITH_TRACING=true
LANGCHAIN_TRACING_V2=true
LANGSMITH_API_KEY=ls-your-langsmith-key
LANGSMITH_WORKSPACE_ID=your-workspace-id
LANGSMITH_WORKSPACE_NAME=your-workspace-name

# Server
HOST=0.0.0.0
PORT=8000

# Rollout
ROLLOUT_BASELINE_V1=10
ROLLOUT_OPTIMIZED_V2=20
ROLLOUT_CURRENT_V3=70
